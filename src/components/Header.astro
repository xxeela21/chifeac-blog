---
import ThemeToggle from './ThemeToggle.astro';
import LangSwitch from './LangSwitch.astro';

interface Props {
  lang: string;
  alternateUrl?: string;
}

const { lang, alternateUrl } = Astro.props;

const nav = lang === 'it'
  ? { blog: 'articoli', about: 'chi sono' }
  : { blog: 'articles', about: 'about' };
---

<header>
  <nav aria-label="Main navigation">
    <a href={`/${lang}/`} class="site-id" aria-label="Alexandru Chifeac – home">ac</a>
    <div class="nav-links">
      <a href={`/${lang}/`}>{nav.blog}</a>
      <a href={`/${lang}/about`}>{nav.about}</a>
      <LangSwitch lang={lang} alternateUrl={alternateUrl} />
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  header {
    padding: 2rem 0 3.5rem;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-id {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--accent);
  }

  .site-id:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--muted);
    transition: color 0.15s;
  }

  .nav-links a:hover {
    color: var(--accent);
  }
</style>
