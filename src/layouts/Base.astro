---
import '../styles/global.css';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
  lang?: string;
  canonicalUrl?: string;
  alternateUrl?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  lang = 'it',
  canonicalUrl = Astro.url.href,
  alternateUrl,
  ogImage,
  ogType = 'website',
} = Astro.props;

const siteName = 'Alexandru Chifeac';
const homepageTagline = lang === 'it'
  ? 'AI, automazioni e agenti'
  : 'AI, automations and agents';
const fullTitle = (title === siteName
  ? `${siteName} — ${homepageTagline}`
  : `${title} — ${siteName}`).toLowerCase();
const alternateLang = lang === 'it' ? 'en' : 'it';
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Prevent FOUC: apply saved theme before first paint; mark JS active for typewriter -->
    <script is:inline>
      const saved = localStorage.getItem('theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
      document.documentElement.classList.add('js');
    </script>

    <!-- SEO -->
    <SEO
      title={fullTitle}
      ogTitle={title}
      description={description}
      canonicalURL={canonicalUrl}
      lang={lang as 'it' | 'en'}
      ogType={ogType}
      ogImage={ogImage}
    />

    <!-- hreflang (alternateUrl è un percorso root-relative, es. /en/) -->
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    {alternateUrl && Astro.site && (
      <link rel="alternate" hreflang={alternateLang} href={new URL(alternateUrl, Astro.site).href} />
    )}
    {Astro.site && <link rel="alternate" hreflang="x-default" href={new URL('/it/', Astro.site).href} />}

    <!-- RSS autodiscovery -->
    <link rel="alternate" type="application/rss+xml" title={`${siteName} (IT)`} href="/it/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${siteName} (EN)`} href="/en/rss.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
  </head>
  <body>
    <div class="container">
      <slot />
    </div>
  </body>
</html>
