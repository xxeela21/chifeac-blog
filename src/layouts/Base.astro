---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: string;
  canonicalUrl?: string;
  alternateUrl?: string;
  ogImage?: string;
}

const {
  title,
  description,
  lang = 'it',
  canonicalUrl = Astro.url.href,
  alternateUrl,
  ogImage,
} = Astro.props;

const siteName = 'Alexandru Chifeac';
const fullTitle = title === siteName ? siteName : `${title} — ${siteName}`;
const alternateLang = lang === 'it' ? 'en' : 'it';
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Prevent FOUC: apply saved theme before first paint; mark JS active for typewriter -->
    <script is:inline>
      const saved = localStorage.getItem('theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
      document.documentElement.classList.add('js');
    </script>

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    {ogImage && Astro.site && <meta property="og:image" content={new URL(ogImage, Astro.site).href} />}

    <!-- hreflang (alternateUrl è un percorso root-relative, es. /en/) -->
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    {alternateUrl && Astro.site && (
      <link rel="alternate" hreflang={alternateLang} href={new URL(alternateUrl, Astro.site).href} />
    )}
    {Astro.site && <link rel="alternate" hreflang="x-default" href={new URL('/it/', Astro.site).href} />}

    <!-- RSS autodiscovery -->
    <link rel="alternate" type="application/rss+xml" title={`${siteName} (IT)`} href="/it/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${siteName} (EN)`} href="/en/rss.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="container">
      <slot />
    </div>
  </body>
</html>
