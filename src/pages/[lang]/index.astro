---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as 'it' | 'en';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => p.id.startsWith(`${lang}/`) && !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

function getSlug(id: string): string {
  return id.split('/').slice(1).join('/').replace(/\.md$/, '');
}

const taglines = {
  it: "Smanettone curioso che usa l'AI ogni giorno. Racconto cosa funziona, cosa no, e perché.",
  en: "A curious tinkerer who uses AI every day. I share what works, what doesn't, and why.",
};

const alternateLang = lang === 'it' ? 'en' : 'it';
const alternateUrl = `/${alternateLang}/`;
const canonicalUrl = Astro.site ? new URL(`/${lang}/`, Astro.site).href : Astro.url.href;
---

<Base
  title="Alexandru Chifeac"
  description={taglines[lang]}
  lang={lang}
  canonicalUrl={canonicalUrl}
  alternateUrl={alternateUrl}
>
  <Header lang={lang} alternateUrl={alternateUrl} />

  <main>
    <section class="hero">
      <p class="prompt">
        <span class="prompt-char" aria-hidden="true">&gt;&nbsp;</span><span class="name">Alexandru Chifeac</span><span class="cursor" aria-hidden="true">▋</span>
      </p>
      <p class="tagline">{taglines[lang]}</p>
    </section>

    <hr class="divider" />

    <section aria-label={lang === 'it' ? 'Articoli' : 'Articles'}>
      {posts.length === 0 ? (
        <p class="empty">
          {lang === 'it' ? 'Primo articolo in arrivo.' : 'First article coming soon.'}
        </p>
      ) : (
        <ul class="post-log" role="list">
          {posts.map(post => {
            const slug = getSlug(post.id);
            const isoDate = post.data.pubDate.toISOString().slice(0, 10);
            return (
              <li class="post-entry">
                <time class="post-date" datetime={isoDate}>{isoDate}</time>
                <a class="post-title" href={`/${lang}/blog/${slug}`}>
                  {post.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </section>
  </main>
</Base>

<style>
  .hero {
    padding: 3rem 0 2rem;
  }

  .prompt {
    font-family: var(--font-mono);
    font-size: var(--text-hero);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .prompt-char {
    color: var(--accent);
  }

  .tagline {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--muted);
    max-width: 440px;
  }

  .post-log {
    list-style: none;
    padding: 0;
  }

  .post-entry {
    display: grid;
    grid-template-columns: 10ch 1fr;
    gap: 1.5rem;
    align-items: baseline;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    white-space: nowrap;
  }

  .post-title {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-title:hover {
    color: var(--accent);
  }

  .empty {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
  }

  @media (max-width: 480px) {
    .post-entry {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
